    "electron:build": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/three": "^0.185.0",
    "concurrently": "^10.0.3",
    "electron": "^31.6.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "wait-on": "^9.0.10"
  }
}
